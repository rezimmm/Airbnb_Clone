<%- include('partials/head') %>
  </head>
  <body class="bg-surface-50 min-h-screen flex flex-col">
    <%- include('partials/nav') %>
    
    <main class="container mx-auto px-4 py-24 flex-1 animate-fade-in flex flex-col items-center justify-center text-center">
      <div class="relative mb-12">
        <span class="text-[180px] font-black text-surface-100 select-none">404</span>
        <div class="absolute inset-0 flex items-center justify-center">
          <i class="fa-solid fa-ghost text-6xl text-brand animate-bounce"></i>
        </div>
      </div>
      
      <h1 class="text-4xl font-bold text-surface-900 mb-4">You've strayed too far</h1>
      <p class="text-lg text-surface-500 max-w-sm mx-auto mb-10 font-medium">
        We can't seem to find the page you're looking for. Let's get you back to familiar grounds.
      </p>
      
      <a href="/" class="btn-primary flex items-center gap-2 px-8">
        <i class="fa-solid fa-house-chimney text-sm"></i>
        <span>Return to Home</span>
      </a>
    </main>

    <style>
      @keyframes fade-in {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-in { animation: fade-in 0.6s ease-out forwards; }
    </style>
  </body>
</html>
