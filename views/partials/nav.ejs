<header class="glass-header sticky top-0 z-50">
  <nav class="container mx-auto px-4 py-3">
    <!-- Desktop Navigation -->
    <div class="hidden md:flex justify-between items-center h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center text-brand font-bold text-2xl tracking-tighter">
        <i class="fa-brands fa-airbnb text-3xl mr-2"></i>
        <span>airbnb</span>
      </a>

      <!-- Centered Search Mockup -->
      <div class="flex-1 max-w-md mx-8">
        <div class="flex items-center border border-surface-200 rounded-full shadow-sm hover:shadow-md transition-shadow py-2 px-4 cursor-pointer bg-white">
          <button class="font-semibold text-sm px-4 border-r border-surface-200">Anywhere</button>
          <button class="font-semibold text-sm px-4 border-r border-surface-200">Any week</button>
          <button class="text-surface-400 text-sm px-4">Add guests</button>
          <div class="bg-brand text-white p-2 rounded-full ml-auto">
            <i class="fa-solid fa-magnifying-glass text-xs"></i>
          </div>
        </div>
      </div>

      <!-- Action Links -->
      <div class="flex items-center gap-4">
        <ul class="flex items-center gap-1 text-surface-600 font-medium text-sm">
          <% if (isLoggedIn) { %>
            <% if (user && user.userType === 'guest') { %>
              <li>
                <a href="/homes" class="<%= currentPage === 'Home' ? 'text-brand' : 'hover:bg-surface-50' %> py-2 px-4 rounded-full transition duration-300">
                  Homes
                </a>
              </li>
              <li>
                <a href="/favourites" class="<%= currentPage === 'favourites' ? 'text-brand' : 'hover:bg-surface-50' %> py-2 px-4 rounded-full transition duration-300">
                  Favourites
                </a>
              </li>
              <li>
                <a href="/bookings" class="<%= currentPage === 'bookings' ? 'text-brand' : 'hover:bg-surface-50' %> py-2 px-4 rounded-full transition duration-300">
                  Bookings
                </a>
              </li>
            <% } else { %>
              <li>
                <a href="/host/host-home-list" class="<%= currentPage === 'host-homes' ? 'text-brand' : 'hover:bg-surface-50' %> py-2 px-4 rounded-full transition duration-300">
                  Host Homes
                </a>
              </li>
              <li>
                <a href="/host/add-home" class="<%= currentPage === 'addHome' ? 'text-brand' : 'hover:bg-surface-50' %> py-2 px-4 rounded-full transition duration-300">
                  Add Home
                </a>
              </li>
            <% } %>
          <% } %>
        </ul>

        <div class="flex items-center gap-3">
          <% if (!isLoggedIn) { %>
            <a href="/login" class="text-surface-600 font-medium hover:bg-surface-50 py-2 px-4 rounded-full transition duration-300">
              Login
            </a>
            <a href="/signup" class="btn-primary py-2 px-5">
              Sign Up
            </a>
          <% } else { %>
            <div class="relative group">
              <button class="flex items-center gap-2 border border-surface-200 p-1.5 pl-3 rounded-full hover:shadow-md transition-all">
                <i class="fa-solid fa-bars text-surface-500"></i>
                <div class="w-8 h-8 rounded-full bg-surface-500 text-white flex items-center justify-center">
                  <i class="fa-solid fa-user text-xs"></i>
                </div>
              </button>
              
              <div class="absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-premium border border-surface-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 py-2">
                <div class="px-4 py-2 border-b border-surface-50 mb-1">
                  <p class="text-xs text-surface-400 font-medium">Signed in as</p>
                  <p class="text-sm font-semibold truncate"><%= user.email %></p>
                </div>
                <form action="/logout" method="POST">
                  <button type="submit" class="w-full text-left px-4 py-2 text-sm text-red-500 hover:bg-red-50 transition-colors">
                    Logout
                  </button>
                </form>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div class="md:hidden flex justify-between items-center h-14">
      <a href="/" class="text-brand font-bold text-xl flex items-center">
        <i class="fa-brands fa-airbnb text-2xl mr-1"></i>
        <span>airbnb</span>
      </a>

      <button id="mobile-menu-button" class="p-2 text-surface-600 rounded-full hover:bg-surface-50">
        <i class="fa-solid fa-bars text-xl"></i>
      </button>
    </div>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-white border-b border-surface-100 shadow-xl overflow-hidden py-4 px-6 animate-fade-in">
      <ul class="flex flex-col gap-3">
        <% if (isLoggedIn) { %>
          <li><a href="/homes" class="block py-2 text-surface-600 font-medium border-b border-surface-50">Homes List</a></li>
          <li><a href="/favourites" class="block py-2 text-surface-600 font-medium border-b border-surface-50">Favourites</a></li>
          <li><a href="/bookings" class="block py-2 text-surface-600 font-medium border-b border-surface-50">Bookings</a></li>
          <li><a href="/host/host-home-list" class="block py-2 text-surface-600 font-medium border-b border-surface-50">Host Homes</a></li>
          <li><a href="/host/add-home" class="block py-2 text-surface-600 font-medium border-b border-surface-50">Add Home</a></li>
          <li>
            <form action="/logout" method="POST" class="pt-2">
              <button type="submit" class="w-full text-left py-2 text-red-500 font-semibold">Logout</button>
            </form>
          </li>
        <% } else { %>
          <li><a href="/login" class="block py-2 text-surface-600 font-medium border-b border-surface-50">Login</a></li>
          <li><a href="/signup" class="block py-2 btn-primary text-center mt-2">Sign Up</a></li>
        <% } %>
      </ul>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  document.getElementById("mobile-menu-button")?.addEventListener("click", function () {
    const menu = document.getElementById("mobile-menu");
    menu.classList.toggle("hidden");
  });
</script>
