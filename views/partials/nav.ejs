<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-surface-100 transition-all duration-300">
  <div class="max-w-[2520px] mx-auto xl:px-20 md:px-10 sm:px-2 px-4">
    <div class="flex flex-row items-center justify-between gap-3 md:gap-0 py-4 h-20">
      <!-- Logo -->
      <div class="flex-shrink-0 cursor-pointer group">
        <a href="/" class="flex items-center gap-2">
          <div class="w-10 h-10 bg-brand rounded-xl flex items-center justify-center transform group-hover:rotate-12 transition-transform duration-300 shadow-lg shadow-brand/20">
            <i class="fa-solid fa-sparkles text-white text-xl"></i>
          </div>
          <span class="hidden lg:block text-brand text-2xl font-black tracking-tighter">AuraStay</span>
        </a>
      </div>

      <!-- Centered Search Mockup (Desktop) -->
      <div class="hidden md:block flex-1 max-w-md mx-8">
        <form action="/" method="GET" class="flex items-center border border-surface-200 rounded-full shadow-sm hover:shadow-md transition-all duration-300 py-1.5 px-2 cursor-pointer bg-white group/search">
          <input 
            type="text" 
            name="search" 
            placeholder="Search destination..." 
            class="w-full bg-transparent focus:outline-none font-bold text-[13px] px-6 text-surface-900 border-none placeholder:text-surface-400"
            value="<%= typeof currentSearch !== 'undefined' ? currentSearch : '' %>"
          />
          <button type="submit" class="bg-brand text-white p-2.5 rounded-full ml-auto group-hover/search:scale-105 transition-transform shadow-md">
            <i class="fa-solid fa-magnifying-glass text-[10px]"></i>
          </button>
        </form>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-3">
        <div class="hidden md:flex items-center">
            <% if (isLoggedIn && user && user.userType === 'host') { %>
                <a href="/host/add-home" class="text-sm font-bold text-surface-700 hover:bg-surface-50 px-4 py-3 rounded-full transition">Switch to hosting</a>
            <% } %>
            <button class="w-10 h-10 flex items-center justify-center text-surface-600 hover:bg-surface-50 rounded-full transition">
                <i class="fa-solid fa-globe text-sm"></i>
            </button>
        </div>

        <!-- Profile Menu -->
        <div class="relative group">
          <button class="flex items-center gap-3 border border-surface-200 p-2 pl-4 rounded-full hover:shadow-md transition-all bg-white overflow-hidden">
            <i class="fa-solid fa-bars text-surface-600 text-sm"></i>
            <div class="w-8 h-8 rounded-full bg-surface-900 text-white flex items-center justify-center border-2 border-white shadow-sm">
                <% if (isLoggedIn) { %>
                    <span class="text-[10px] font-bold uppercase"><%= user.email.charAt(0) %></span>
                <% } else { %>
                    <i class="fa-solid fa-user text-[10px]"></i>
                <% } %>
            </div>
          </button>
          
          <!-- Dropdown -->
          <div class="absolute right-0 mt-3 w-64 bg-white rounded-3xl shadow-premium border border-surface-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 py-3 origin-top-right transform scale-95 group-hover:scale-100">
            <div class="space-y-1">
                <% if (!isLoggedIn) { %>
                    <a href="/signup" class="block px-4 py-2 text-sm font-bold text-surface-900 hover:bg-surface-50 transition">Sign up</a>
                    <a href="/login" class="block px-4 py-2 text-sm font-medium text-surface-600 hover:bg-surface-50 transition border-b border-surface-50 pb-3">Log in</a>
                <% } else { %>
                    <div class="px-4 py-3 border-b border-surface-50 mb-2">
                        <p class="text-[10px] uppercase font-bold text-surface-400 tracking-widest mb-1">Authenticated as</p>
                        <p class="text-sm font-bold text-surface-900 truncate"><%= user.email %></p>
                    </div>
                <% } %>

                <div class="py-1">
                    <a href="/homes" class="block px-4 py-2 text-sm font-medium text-surface-600 hover:bg-surface-50 transition">Explore Homes</a>
                    <% if (isLoggedIn) { %>
                        <a href="/favourites" class="block px-4 py-2 text-sm font-medium text-surface-600 hover:bg-surface-50 transition">Wishlist</a>
                        <a href="/bookings" class="block px-4 py-2 text-sm font-medium text-surface-600 hover:bg-surface-50 transition">Trips</a>
                        <div class="border-t border-surface-50 my-1"></div>
                        <% if (user.userType === 'host') { %>
                            <a href="/host/host-home-list" class="block px-4 py-2 text-sm font-medium text-surface-600 hover:bg-surface-50 transition">Your Properties</a>
                            <a href="/host/add-home" class="block px-4 py-2 text-sm font-medium text-surface-700 hover:bg-surface-50 transition">AuraStay your home</a>
                        <% } %>
                        <form action="/logout" method="POST" class="pt-1">
                            <button type="submit" class="w-full text-left px-4 py-2 text-sm font-bold text-brand hover:bg-red-50 transition">Log out</button>
                        </form>
                    <% } %>
                </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
    // Scroll effect for header
    window.addEventListener('scroll', () => {
        const header = document.querySelector('header');
        if (window.scrollY > 0) {
            header.classList.add('shadow-md');
            header.classList.add('py-1');
        } else {
            header.classList.remove('shadow-md');
            header.classList.remove('py-1');
        }
    });
</script>
