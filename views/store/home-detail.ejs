<%- include('../partials/head') %>
  </head>
  <body class="bg-white">
    <%- include('../partials/nav') %>
    
    <main class="container mx-auto px-4 mt-8 pb-20 max-w-7xl animate-fade-in">
      <!-- Title Section -->
      <div class="mb-6 flex justify-between items-end">
        <div>
          <h1 class="text-3xl font-semibold text-surface-900 mb-2"><%= home.houseName %></h1>
          <div class="flex items-center gap-4 text-sm font-medium">
            <div class="flex items-center gap-1">
              <i class="fa-solid fa-star text-xs"></i>
              <span><%= home.rating %></span>
            </div>
            <span class="text-surface-300">•</span>
            <a href="#" class="underline hover:text-surface-900 transition-colors"><%= home.location %></a>
          </div>
        </div>
        <div class="flex gap-2">
          <button class="flex items-center gap-2 hover:bg-surface-50 px-3 py-2 rounded-lg transition-colors text-sm font-semibold">
            <i class="fa-solid fa-share-nodes"></i>
            <span>Share</span>
          </button>
        </div>
      </div>

      <!-- Hero Gallery (Mockup Layout) -->
      <div class="grid grid-cols-4 grid-rows-2 gap-2 h-[500px] mb-10 overflow-hidden rounded-2xl group">
        <div class="col-span-2 row-span-2 overflow-hidden">
          <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
        </div>
        <div class="overflow-hidden">
          <img src="<%= home.photo %>" class="w-full h-full object-cover brightness-90 hover:brightness-100 transition-all duration-500">
        </div>
        <div class="overflow-hidden">
          <img src="<%= home.photo %>" class="w-full h-full object-cover brightness-90 hover:brightness-100 transition-all duration-500">
        </div>
        <div class="overflow-hidden">
          <img src="<%= home.photo %>" class="w-full h-full object-cover brightness-90 hover:brightness-100 transition-all duration-500">
        </div>
        <div class="overflow-hidden">
          <img src="<%= home.photo %>" class="w-full h-full object-cover brightness-90 hover:brightness-100 transition-all duration-500">
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-16 relative">
        <!-- Main Content (Left) -->
        <div class="lg:col-span-2 space-y-10">
          <section class="border-b border-surface-100 pb-10">
            <div class="flex justify-between items-start mb-6">
              <div>
                <h2 class="text-2xl font-semibold text-surface-900 mb-1">Entire home in <%= home.location %></h2>
                <p class="text-surface-600">4 guests • 2 bedrooms • 2 beds • 1 washroom</p>
              </div>
              <div class="w-14 h-14 bg-surface-100 rounded-full flex items-center justify-center text-surface-400">
                <i class="fa-solid fa-user text-2xl"></i>
              </div>
            </div>
          </section>

          <section class="border-b border-surface-100 pb-10">
            <div class="flex gap-6 items-start">
              <i class="fa-solid fa-door-open text-2xl mt-1 text-surface-600"></i>
              <div>
                <h3 class="font-semibold text-surface-900">Self check-in</h3>
                <p class="text-surface-400 text-sm">Check yourself in with the keylock.</p>
              </div>
            </div>
            <div class="flex gap-6 items-start mt-6">
              <i class="fa-solid fa-location-dot text-2xl mt-1 text-surface-600"></i>
              <div>
                <h3 class="font-semibold text-surface-900">Great location</h3>
                <p class="text-surface-400 text-sm">95% of recent guests gave the location a 5-star rating.</p>
              </div>
            </div>
          </section>

          <section class="border-b border-surface-100 pb-10">
            <div class="prose prose-slate max-w-none">
              <h3 class="text-2xl font-semibold mb-4">About this place</h3>
              <p class="text-surface-600 leading-relaxed"><%= home.description %></p>
            </div>
          </section>

          <section>
            <h3 class="text-2xl font-semibold mb-6">What this place offers</h3>
            <div class="grid grid-cols-2 gap-y-4">
              <div class="flex items-center gap-4 text-surface-600">
                <i class="fa-solid fa-wifi w-5"></i>
                <span>Fast wifi</span>
              </div>
              <div class="flex items-center gap-4 text-surface-600">
                <i class="fa-solid fa-car w-5"></i>
                <span>Free parking</span>
              </div>
              <div class="flex items-center gap-4 text-surface-600">
                <i class="fa-solid fa-kitchen-set w-5"></i>
                <span>Kitchen</span>
              </div>
              <div class="flex items-center gap-4 text-surface-600">
                <i class="fa-solid fa-tv w-5"></i>
                <span>65" TV</span>
              </div>
            </div>
          </section>
        </div>

        <!-- Sticky Sidebar (Right) -->
        <div class="lg:col-span-1">
          <div class="sticky top-28 p-6 bg-white border border-surface-100 rounded-3xl shadow-premium">
            <div class="flex justify-between items-center mb-6">
              <div>
                <span class="text-2xl font-bold text-surface-900">Rs<%= home.price %></span>
                <span class="text-surface-600"> night</span>
              </div>
              <div class="flex items-center gap-1 text-sm font-semibold">
                <i class="fa-solid fa-star text-xs"></i>
                <span><%= home.rating %></span>
              </div>
            </div>

            <div class="grid grid-cols-2 border border-surface-200 rounded-xl mb-4 overflow-hidden">
              <div class="p-3 border-r border-b border-surface-200">
                <p class="text-[10px] font-bold uppercase tracking-tight">Check-in</p>
                <p class="text-sm">Add date</p>
              </div>
              <div class="p-3 border-b border-surface-200">
                <p class="text-[10px] font-bold uppercase tracking-tight">Checkout</p>
                <p class="text-sm">Add date</p>
              </div>
              <div class="col-span-2 p-3">
                <p class="text-[10px] font-bold uppercase tracking-tight">Guests</p>
                <p class="text-sm">1 guest</p>
              </div>
            </div>

            <button class="w-full btn-primary py-3.5 mb-4 text-lg font-bold">Reserve</button>
            <p class="text-center text-sm text-surface-400 mb-6">You won't be charged yet</p>

            <div class="space-y-4 text-surface-600 border-b border-surface-100 pb-4 mb-4">
              <div class="flex justify-between">
                <span class="underline">Rs<%= home.price %> x 5 nights</span>
                <span>Rs<%= home.price * 5 %></span>
              </div>
              <div class="flex justify-between">
                <span class="underline">AuraStay service fee</span>
                <span>Rs1,200</span>
              </div>
            </div>

            <div class="flex justify-between font-bold text-surface-900 text-lg">
              <span>Total after taxes</span>
              <span>Rs<%= (home.price * 5) + 1200 %></span>
            </div>

            <div class="mt-6 pt-6 border-t border-surface-100">
              <%- include('../partials/favourite') %>
            </div>
          </div>
        </div>
      </div>
    </main>

    <style>
      @keyframes fade-in {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      .animate-fade-in { animation: fade-in 0.8s ease-out; }
    </style>
  </body>
</html>
