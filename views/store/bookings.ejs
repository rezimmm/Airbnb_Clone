<%- include('../partials/head') %>
  </head>
  <body class="bg-surface-50 min-h-screen flex flex-col">
    <%- include('../partials/nav') %>
    
    <main class="container mx-auto px-4 py-20 flex-1 animate-fade-in flex flex-col items-center justify-center text-center">
      <div class="w-24 h-24 bg-white rounded-3xl shadow-premium border border-surface-100 flex items-center justify-center mb-8">
        <i class="fa-solid fa-calendar-check text-4xl text-brand"></i>
      </div>
      
      <h1 class="text-4xl font-bold text-surface-900 mb-4">My Bookings</h1>
      <p class="text-lg text-surface-500 max-w-md mx-auto mb-10 font-medium">
        When you book a stay, your reservation details and itineraries will appear here for easy access.
      </p>
      
      <a href="/homes" class="btn-primary flex items-center gap-2">
        <i class="fa-solid fa-location-arrow text-sm"></i>
        <span>Find your next stay</span>
      </a>
    </main>

    <style>
      @keyframes fade-in {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-in { animation: fade-in 0.6s ease-out forwards; }
    </style>
  </body>
</html>
