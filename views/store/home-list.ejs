<%- include('../partials/head') %>
  </head>
  <body class="bg-surface-50 min-h-screen flex flex-col">
    <%- include('../partials/nav') %>
    
    <main class="container mx-auto px-4 py-12 flex-1 animate-fade-in">
      <div class="mb-10 text-center md:text-left">
        <h1 class="text-3xl font-bold text-surface-900 mb-2">Discover Your Next Home</h1>
        <p class="text-surface-500 font-medium">Explore our curated list of professional properties</p>
      </div>

      <!-- Home Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-10">
        <% registeredHomes.forEach(home => { %>
          <div class="group cursor-pointer">
            <div class="relative aspect-square overflow-hidden rounded-2xl mb-3">
              <img 
                src="<%= home.photo %>" 
                alt="<%= home.houseName %>" 
                class="w-full h-full object-cover transition duration-500 group-hover:scale-110"
              >
              <!-- Heart Badge -->
              <div class="absolute top-3 right-3">
                <%- include('../partials/favourite', {home: home}) %>
              </div>
              <!-- Guest Favorite Badge -->
              <% if (home.rating >= 4.8) { %>
                <div class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm px-2 py-1 rounded-md shadow-sm">
                  <span class="text-[10px] font-bold text-surface-900 uppercase tracking-tight">Guest Favorite</span>
                </div>
              <% } %>
            </div>

            <div class="space-y-1 px-1">
              <div class="flex justify-between items-start">
                <h3 class="font-bold text-surface-900 truncate pr-2"><%= home.houseName %></h3>
                <div class="flex items-center gap-1">
                  <i class="fa-solid fa-star text-[10px] text-surface-900"></i>
                  <span class="text-sm font-semibold text-surface-600"><%= home.rating %></span>
                </div>
              </div>
              <p class="text-surface-500 text-sm font-medium"><%= home.location %></p>
              <div class="flex items-baseline gap-1 pt-1">
                <span class="font-bold text-surface-900">Rs<%= home.price %></span>
                <span class="text-surface-500 text-sm font-medium">night</span>
              </div>
              
              <div class="pt-3">
                <a href="/homes/<%= home._id %>" class="block w-full text-center py-2.5 bg-surface-900 hover:bg-surface-800 text-white rounded-xl text-sm font-bold transition-all shadow-md">
                  View Details
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <% if (registeredHomes.length === 0) { %>
        <div class="py-20 text-center">
          <div class="w-20 h-20 bg-surface-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="fa-solid fa-house-circle-xmark text-3xl text-surface-300"></i>
          </div>
          <h2 class="text-2xl font-bold text-surface-900 mb-2">No homes found</h2>
          <p class="text-surface-500 max-w-sm mx-auto">We couldn't find any homes matching your criteria. Try adjusting your search.</p>
          <a href="/" class="btn-primary inline-block mt-8">Explore All Home</a>
        </div>
      <% } %>
    </main>

    <style>
      @keyframes fade-in {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-in { animation: fade-in 0.6s ease-out forwards; }
    </style>
  </body>
</html>
