<%- include('../partials/head') %>
  </head>
  <body class="bg-white">
    <%- include('../partials/nav') %>
    
    <!-- Category Slide Bar -->
    <div class="sticky top-[73px] z-40 bg-white/95 backdrop-blur-sm border-b border-surface-100 py-4 mb-8">
      <div class="container mx-auto px-4 overflow-x-auto no-scrollbar flex items-center gap-10">
        <div class="flex flex-col items-center gap-2 cursor-pointer group border-b-2 border-surface-900 pb-2">
          <i class="fa-solid fa-house-chimney text-xl text-surface-900"></i>
          <span class="text-xs font-semibold text-surface-900 uppercase tracking-wider">All Homes</span>
        </div>
        <div class="flex flex-col items-center gap-2 cursor-pointer group border-b-2 border-transparent hover:border-surface-300 pb-2 transition-all">
          <i class="fa-solid fa-water text-xl text-surface-400 group-hover:text-surface-600 transition-colors"></i>
          <span class="text-xs font-medium text-surface-400 group-hover:text-surface-600 uppercase tracking-wider">Beachside</span>
        </div>
        <div class="flex flex-col items-center gap-2 cursor-pointer group border-b-2 border-transparent hover:border-surface-300 pb-2 transition-all">
          <i class="fa-solid fa-mountain-sun text-xl text-surface-400 group-hover:text-surface-600 transition-colors"></i>
          <span class="text-xs font-medium text-surface-400 group-hover:text-surface-600 uppercase tracking-wider">Amazing Views</span>
        </div>
        <div class="flex flex-col items-center gap-2 cursor-pointer group border-b-2 border-transparent hover:border-surface-300 pb-2 transition-all">
          <i class="fa-solid fa-fire text-xl text-surface-400 group-hover:text-surface-600 transition-colors"></i>
          <span class="text-xs font-medium text-surface-400 group-hover:text-surface-600 uppercase tracking-wider">Trending</span>
        </div>
        <div class="flex flex-col items-center gap-2 cursor-pointer group border-b-2 border-transparent hover:border-surface-300 pb-2 transition-all">
          <i class="fa-solid fa-snowflake text-xl text-surface-400 group-hover:text-surface-600 transition-colors"></i>
          <span class="text-xs font-medium text-surface-400 group-hover:text-surface-600 uppercase tracking-wider">Arctic</span>
        </div>
        <div class="flex flex-col items-center gap-2 cursor-pointer group border-b-2 border-transparent hover:border-surface-300 pb-2 transition-all">
          <i class="fa-solid fa-tree text-xl text-surface-400 group-hover:text-surface-600 transition-colors"></i>
          <span class="text-xs font-medium text-surface-400 group-hover:text-surface-600 uppercase tracking-wider">Cabins</span>
        </div>
        <div class="flex flex-col items-center gap-2 cursor-pointer group border-b-2 border-transparent hover:border-surface-300 pb-2 transition-all">
          <i class="fa-solid fa-crown text-xl text-surface-400 group-hover:text-surface-600 transition-colors"></i>
          <span class="text-xs font-medium text-surface-400 group-hover:text-surface-600 uppercase tracking-wider">Luxe</span>
        </div>
      </div>
    </div>

    <main class="container mx-auto px-4 mb-20 animate-fade-in-up">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-10">
        <% registeredHomes.forEach(home => { %>
          <div class="group cursor-pointer">
            <!-- Image Container -->
            <div class="relative aspect-square mb-3 overflow-hidden rounded-2xl">
              <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-full object-cover transition duration-500 group-hover:scale-110">
              
              <!-- Badge -->
              <div class="absolute top-3 right-3">
                <button class="text-white/80 hover:text-brand transition-colors text-2xl drop-shadow-md">
                  <i class="fa-solid fa-heart"></i>
                </button>
              </div>

              <% if (home.rating >= 4.5) { %>
                <div class="absolute top-3 left-3 bg-white px-3 py-1 rounded-full shadow-md">
                  <span class="text-xs font-bold text-surface-900 uppercase">Guest Favorite</span>
                </div>
              <% } %>
            </div>

            <!-- Details -->
            <div class="flex flex-col gap-1">
              <div class="flex justify-between items-start">
                <h3 class="font-semibold text-surface-900 truncate pr-4"><%= home.houseName %></h3>
                <div class="flex items-center gap-1">
                  <i class="fa-solid fa-star text-[10px] text-surface-900"></i>
                  <span class="text-sm font-light text-surface-600"><%= home.rating %></span>
                </div>
              </div>
              <p class="text-surface-400 text-sm font-light"><%= home.location %></p>
              <p class="text-surface-400 text-sm font-light">Available now</p>
              <div class="mt-1">
                <span class="font-semibold text-surface-900">Rs<%= home.price %></span>
                <span class="text-surface-600 font-light"> night</span>
              </div>
              
              <a href="/homes/<%= home._id %>" class="mt-3 btn-primary text-center text-sm py-2">View Details</a>
            </div>
          </div>
        <% }) %>
      </div>

      <% if (registeredHomes.length === 0) { %>
        <div class="flex flex-col items-center justify-center py-20 text-center">
          <div class="w-20 h-20 bg-surface-50 rounded-full flex items-center justify-center mb-4">
            <i class="fa-solid fa-house-circle-exclamation text-3xl text-surface-200"></i>
          </div>
          <div class="mb-12 text-center">
            <h1 class="text-4xl md:text-5xl font-black text-surface-900 mb-3 tracking-tight">Experience the extraordinary with AuraStay</h1>
            <p class="text-surface-500 font-medium text-lg">Curated stays for the modern traveler</p>
          </div>
        </div>
      <% } %>
    </main>

    <style>
      .no-scrollbar::-webkit-scrollbar { display: none; }
      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      
      @keyframes fade-in-up {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-in-up { animation: fade-in-up 0.6s ease-out forwards; }
    </style>
  </body>
</html>
