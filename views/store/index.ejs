<%- include('../partials/head') %>
  </head>
  <body class="bg-white">
    <%- include('../partials/nav') %>
    
    <!-- Category Slide Bar -->
    <div class="sticky top-[73px] z-40 bg-white/95 backdrop-blur-sm border-b border-surface-100 py-4 mb-8">
      <div class="container mx-auto px-4 overflow-x-auto no-scrollbar flex items-center justify-start md:justify-center gap-10">
        <a href="/?category=all" class="flex flex-col items-center gap-2 cursor-pointer group border-b-2 pb-2 transition-all <%= currentCategory === 'all' ? 'border-surface-900' : 'border-transparent hover:border-surface-300' %>">
          <i class="fa-solid fa-house-chimney text-xl <%= currentCategory === 'all' ? 'text-surface-900' : 'text-surface-400 group-hover:text-surface-600' %>"></i>
          <span class="text-xs <%= currentCategory === 'all' ? 'font-bold text-surface-900' : 'font-medium text-surface-400 group-hover:text-surface-600' %> uppercase tracking-wider">All Homes</span>
        </a>
        <a href="/?category=beachside" class="flex flex-col items-center gap-2 cursor-pointer group border-b-2 pb-2 transition-all <%= currentCategory === 'beachside' ? 'border-surface-900' : 'border-transparent hover:border-surface-300' %>">
          <i class="fa-solid fa-water text-xl <%= currentCategory === 'beachside' ? 'text-surface-900' : 'text-surface-400 group-hover:text-surface-600' %>"></i>
          <span class="text-xs <%= currentCategory === 'beachside' ? 'font-bold text-surface-900' : 'font-medium text-surface-400 group-hover:text-surface-600' %> uppercase tracking-wider">Beachside</span>
        </a>
        <a href="/?category=views" class="flex flex-col items-center gap-2 cursor-pointer group border-b-2 pb-2 transition-all <%= currentCategory === 'views' ? 'border-surface-900' : 'border-transparent hover:border-surface-300' %>">
          <i class="fa-solid fa-mountain-sun text-xl <%= currentCategory === 'views' ? 'text-surface-900' : 'text-surface-400 group-hover:text-surface-600' %>"></i>
          <span class="text-xs <%= currentCategory === 'views' ? 'font-bold text-surface-900' : 'font-medium text-surface-400 group-hover:text-surface-600' %> uppercase tracking-wider">Amazing Views</span>
        </a>
        <a href="/?category=trending" class="flex flex-col items-center gap-2 cursor-pointer group border-b-2 pb-2 transition-all <%= currentCategory === 'trending' ? 'border-surface-900' : 'border-transparent hover:border-surface-300' %>">
          <i class="fa-solid fa-fire text-xl <%= currentCategory === 'trending' ? 'text-surface-900' : 'text-surface-400 group-hover:text-surface-600' %>"></i>
          <span class="text-xs <%= currentCategory === 'trending' ? 'font-bold text-surface-900' : 'font-medium text-surface-400 group-hover:text-surface-600' %> uppercase tracking-wider">Trending</span>
        </a>
        <a href="/?category=arctic" class="flex flex-col items-center gap-2 cursor-pointer group border-b-2 pb-2 transition-all <%= currentCategory === 'arctic' ? 'border-surface-900' : 'border-transparent hover:border-surface-300' %>">
          <i class="fa-solid fa-snowflake text-xl <%= currentCategory === 'arctic' ? 'text-surface-900' : 'text-surface-400 group-hover:text-surface-600' %>"></i>
          <span class="text-xs <%= currentCategory === 'arctic' ? 'font-bold text-surface-900' : 'font-medium text-surface-400 group-hover:text-surface-600' %> uppercase tracking-wider">Arctic</span>
        </a>
        <a href="/?category=cabins" class="flex flex-col items-center gap-2 cursor-pointer group border-b-2 pb-2 transition-all <%= currentCategory === 'cabins' ? 'border-surface-900' : 'border-transparent hover:border-surface-300' %>">
          <i class="fa-solid fa-tree text-xl <%= currentCategory === 'cabins' ? 'text-surface-900' : 'text-surface-400 group-hover:text-surface-600' %>"></i>
          <span class="text-xs <%= currentCategory === 'cabins' ? 'font-bold text-surface-900' : 'font-medium text-surface-400 group-hover:text-surface-600' %> uppercase tracking-wider">Cabins</span>
        </a>
        <a href="/?category=luxe" class="flex flex-col items-center gap-2 cursor-pointer group border-b-2 pb-2 transition-all <%= currentCategory === 'luxe' ? 'border-surface-900' : 'border-transparent hover:border-surface-300' %>">
          <i class="fa-solid fa-crown text-xl <%= currentCategory === 'luxe' ? 'text-surface-900' : 'text-surface-400 group-hover:text-surface-600' %>"></i>
          <span class="text-xs <%= currentCategory === 'luxe' ? 'font-bold text-surface-900' : 'font-medium text-surface-400 group-hover:text-surface-600' %> uppercase tracking-wider">Luxe</span>
        </a>
      </div>
    </div>

    <main class="container mx-auto px-4 mb-20 animate-fade-in-up">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-10">
        <% registeredHomes.forEach(home => { %>
          <div class="group cursor-pointer">
            <!-- Image Container -->
            <div class="relative aspect-square mb-3 overflow-hidden rounded-2xl">
              <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-full object-cover transition duration-500 group-hover:scale-110">
              
              <!-- Favorite Toggle -->
              <div class="absolute top-3 right-3 z-10">
                <form action="/favourites" method="POST">
                  <input type="hidden" name="id" value="<%= home._id %>" />
                  <button type="submit" class="transition-transform active:scale-90 group/heart">
                    <i class="fa-solid fa-heart text-2xl drop-shadow-md transition-colors <%= home.isFavourite ? 'text-brand' : 'text-black/50 hover:text-black/70' %>"></i>
                  </button>
                </form>
              </div>

              <% if (home.rating >= 4.5) { %>
                <div class="absolute top-3 left-3 bg-white px-3 py-1 rounded-full shadow-md">
                  <span class="text-xs font-bold text-surface-900 uppercase">Guest Favorite</span>
                </div>
              <% } %>
            </div>

            <!-- Details -->
            <div class="flex flex-col items-center text-center gap-1">
              <div class="flex flex-col items-center">
                <h3 class="font-semibold text-surface-900 truncate max-w-full"><%= home.houseName %></h3>
                <div class="flex items-center gap-1 mt-0.5">
                  <i class="fa-solid fa-star text-[10px] text-surface-900"></i>
                  <span class="text-sm font-light text-surface-600"><%= home.rating %></span>
                </div>
              </div>
              <p class="text-surface-400 text-sm font-light mt-1"><%= home.location %></p>
              <p class="text-surface-400 text-sm font-light">Available now</p>
              <div class="mt-1">
                <span class="font-semibold text-surface-900">Rs<%= home.price %></span>
                <span class="text-surface-600 font-light"> night</span>
              </div>
              
              <a href="/homes/<%= home._id %>" class="mt-4 btn-primary w-full text-center text-sm py-2 px-8">View Details</a>
            </div>
          </div>
        <% }) %>
      </div>

      <% if (registeredHomes.length === 0) { %>
        <div class="flex flex-col items-center justify-center py-20 text-center">
          <div class="w-20 h-20 bg-surface-50 rounded-full flex items-center justify-center mb-4">
            <i class="fa-solid fa-house-circle-exclamation text-3xl text-surface-200"></i>
          </div>
          <div class="mb-12 text-center">
            <h1 class="text-4xl md:text-5xl font-black text-surface-900 mb-3 tracking-tight">Experience the extraordinary with AuraStay</h1>
            <p class="text-surface-500 font-medium text-lg">Curated stays for the modern traveler</p>
          </div>
        </div>
      <% } %>
    </main>

    <style>
      .no-scrollbar::-webkit-scrollbar { display: none; }
      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      
      @keyframes fade-in-up {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-in-up { animation: fade-in-up 0.6s ease-out forwards; }
    </style>
  </body>
</html>
