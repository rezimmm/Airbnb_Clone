<%- include('../partials/head') %>
  </head>
  <body class="bg-surface-50 min-h-screen flex flex-col">
    <%- include('../partials/nav') %>
    
    <main class="container mx-auto px-4 py-12 flex-1 animate-fade-in">
      <div class="mb-10 text-center md:text-left flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
          <h1 class="text-3xl font-bold text-surface-900 mb-2">My Collections</h1>
          <p class="text-surface-500 font-medium">All the places you've dreamed of visiting</p>
        </div>
        <div class="text-sm font-bold text-surface-400 uppercase tracking-widest bg-white px-4 py-2 rounded-full border border-surface-100">
          <%= favouriteHomes.length %> Saved Properties
        </div>
      </div>

      <!-- Favourite Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-10">
        <% favouriteHomes.forEach(home => { %>
          <div class="group relative">
            <div class="relative aspect-square overflow-hidden rounded-2xl mb-3">
              <img 
                src="<%= home.photo %>" 
                alt="<%= home.houseName %>" 
                class="w-full h-full object-cover transition duration-500 group-hover:scale-110"
              >
              <!-- Removal Button Overlay -->
              <form action="/favourites/delete/<%= home._id %>" method="POST" class="absolute top-3 right-3">
                <button type="submit" class="w-10 h-10 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center text-brand hover:bg-brand hover:text-white transition-all shadow-md group/remove">
                  <i class="fa-solid fa-heart-crack text-sm"></i>
                  <span class="absolute right-full mr-2 opacity-0 group-hover/remove:opacity-100 transition-opacity bg-surface-900 text-white text-[10px] px-2 py-1 rounded whitespace-nowrap pointer-events-none">Unsave</span>
                </button>
              </form>
            </div>

            <div class="space-y-1 px-1">
              <div class="flex justify-between items-start">
                <h3 class="font-bold text-surface-900 truncate pr-2"><%= home.houseName %></h3>
                <div class="flex items-center gap-1">
                  <i class="fa-solid fa-star text-[10px] text-surface-900"></i>
                  <span class="text-sm font-semibold text-surface-600"><%= home.rating %></span>
                </div>
              </div>
              <p class="text-surface-500 text-sm font-medium"><%= home.location %></p>
              <div class="flex items-baseline gap-1 pt-1">
                <span class="font-bold text-surface-900">Rs<%= home.price %></span>
                <span class="text-surface-500 text-sm font-medium">night</span>
              </div>
              
              <div class="pt-3">
                <a href="/homes/<%= home._id %>" class="block w-full text-center py-2.5 bg-surface-900 hover:bg-surface-800 text-white rounded-xl text-sm font-bold transition-all shadow-md">
                  View Details
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <% if (favouriteHomes.length === 0) { %>
        <div class="py-24 text-center">
          <div class="w-24 h-24 bg-surface-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="fa-solid fa-heart-circle-plus text-4xl text-surface-200"></i>
          </div>
          <h2 class="text-2xl font-bold text-surface-900 mb-2">Your collection is empty</h2>
          <p class="text-surface-500 max-w-sm mx-auto mb-8">Save properties you love to find them easily when you're ready to book.</p>
          <a href="/homes" class="btn-primary inline-flex items-center gap-2">
            <i class="fa-solid fa-magnifying-glass text-sm"></i>
            <span>Browse Homes</span>
          </a>
        </div>
      <% } %>
    </main>

    <style>
      @keyframes fade-in {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-in { animation: fade-in 0.6s ease-out forwards; }
    </style>
  </body>
</html>
