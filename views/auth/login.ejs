<%- include('../partials/head') %>
  </head>
  <body class="bg-surface-50 min-h-screen flex flex-col">
    <%- include('../partials/nav') %>
    
    <main class="flex-1 flex items-center justify-center p-4 py-20 animate-fade-in">
      <div class="w-full max-w-md bg-white rounded-3xl shadow-premium border border-surface-100 p-8 md:p-10">
        <div class="text-center mb-10">
          <h1 class="text-3xl font-bold text-surface-900 mb-2">Welcome Back</h1>
          <p class="text-surface-400 font-medium">Log in to continue your journey</p>
        </div>
        
        <form action="/login" method="POST" class="space-y-6">
          <%- include('../partials/errors') %>
          
          <!-- Email field -->
          <div>
            <label for="email" class="block text-xs font-bold uppercase tracking-wider text-surface-500 mb-2 ml-1">Email Address</label>
            <div class="relative">
              <span class="absolute inset-y-0 left-4 flex items-center text-surface-300">
                <i class="fa-solid fa-envelope"></i>
              </span>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="name@example.com"
                value="<%= oldInput.email ? oldInput.email : '' %>"
                class="input-premium pl-12"
                required />
            </div>
          </div>
          
          <!-- Password field -->
          <div>
            <div class="flex items-center justify-between mb-2 ml-1">
              <label for="password" class="block text-xs font-bold uppercase tracking-wider text-surface-500">Password</label>
              <a href="#" class="text-xs font-semibold text-brand hover:underline">Forgot?</a>
            </div>
            <div class="relative">
              <span class="absolute inset-y-0 left-4 flex items-center text-surface-300">
                <i class="fa-solid fa-lock"></i>
              </span>
              <input
                type="password"
                id="password"
                name="password"
                placeholder="••••••••"
                class="input-premium pl-12"
                required/>
            </div>
          </div>
          
          <div class="pt-2">
            <button type="submit" class="w-full btn-primary py-4 text-lg font-bold shadow-xl shadow-brand/20">
              Sign In
            </button>
          </div>
          
          <div class="relative py-4">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-surface-100"></div>
            </div>
            <div class="relative flex justify-center text-xs uppercase tracking-widest px-2">
              <span class="bg-white text-surface-300 font-bold">or</span>
            </div>
          </div>

          <p class="text-center text-surface-500 font-medium">
            Don't have an account? <a href="/signup" class="text-brand font-bold hover:underline">Sign up for free</a>
          </p>
        </form>
      </div>
    </main>

    <style>
      @keyframes fade-in {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-in { animation: fade-in 0.5s ease-out forwards; }
    </style>
  </body>
</html>
