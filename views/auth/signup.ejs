<%- include('../partials/head') %>
  </head>
  <body class="bg-surface-50 min-h-screen flex flex-col">
    <%- include('../partials/nav') %>
    
    <main class="flex-1 flex items-center justify-center p-4 py-16 animate-fade-in">
      <div class="w-full max-w-xl bg-white rounded-3xl shadow-premium border border-surface-100 p-8 md:p-10">
        <div class="text-center mb-10">
          <h1 class="text-3xl font-bold text-surface-900 mb-2">Create Your Account</h1>
          <p class="text-surface-400 font-medium">Join our community of hosts and travelers</p>
        </div>
        
        <form action="/signup" method="POST" class="space-y-6">
          <%- include('../partials/errors') %>

          <!-- Name fields in a grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="firstName" class="block text-xs font-bold uppercase tracking-wider text-surface-500 mb-2 ml-1">First Name</label>
              <div class="relative">
                <span class="absolute inset-y-0 left-4 flex items-center text-surface-300">
                  <i class="fa-solid fa-user"></i>
                </span>
                <input
                  type="text"
                  id="firstName"
                  name="firstName"
                  placeholder="John"
                  value="<%= oldInput.firstName ? oldInput.firstName : '' %>"
                  class="input-premium pl-12"
                  required />
              </div>
            </div>
            
            <div>
              <label for="lastName" class="block text-xs font-bold uppercase tracking-wider text-surface-500 mb-2 ml-1">Last Name</label>
              <div class="relative">
                <span class="absolute inset-y-0 left-4 flex items-center text-surface-300">
                  <i class="fa-solid fa-user"></i>
                </span>
                <input
                  type="text"
                  id="lastName"
                  name="lastName"
                  placeholder="Doe"
                  value="<%= oldInput.lastName ? oldInput.lastName : '' %>"
                  class="input-premium pl-12" />
              </div>
            </div>
          </div>
          
          <!-- Email field -->
          <div>
            <label for="email" class="block text-xs font-bold uppercase tracking-wider text-surface-500 mb-2 ml-1">Email Address</label>
            <div class="relative">
              <span class="absolute inset-y-0 left-4 flex items-center text-surface-300">
                <i class="fa-solid fa-envelope"></i>
              </span>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="name@example.com"
                value="<%= oldInput.email ? oldInput.email : '' %>"
                class="input-premium pl-12"
                required />
            </div>
          </div>
          
          <!-- Password fields -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="password" class="block text-xs font-bold uppercase tracking-wider text-surface-500 mb-2 ml-1">Password</label>
              <div class="relative">
                <span class="absolute inset-y-0 left-4 flex items-center text-surface-300">
                  <i class="fa-solid fa-lock"></i>
                </span>
                <input
                  type="password"
                  id="password"
                  name="password"
                  placeholder="••••••••"
                  class="input-premium pl-12"
                  required/>
              </div>
            </div>
            
            <div>
              <label for="confirmPassword" class="block text-xs font-bold uppercase tracking-wider text-surface-500 mb-2 ml-1">Confirm</label>
              <div class="relative">
                <span class="absolute inset-y-0 left-4 flex items-center text-surface-300">
                  <i class="fa-solid fa-shield-halved"></i>
                </span>
                <input
                  type="password"
                  id="confirmPassword"
                  name="confirmPassword"
                  placeholder="••••••••"
                  class="input-premium pl-12"
                  required/>
              </div>
            </div>
          </div>

          <!-- User type selection -->
          <div class="p-5 bg-surface-50 rounded-2xl border border-surface-100">
            <p class="text-sm font-bold text-surface-700 mb-4">I want to register as:</p>
            <div class="flex gap-8">
              <label class="flex items-center gap-3 cursor-pointer group">
                <div class="relative w-5 h-5 flex items-center justify-center">
                  <input type="radio" name="userType" value="guest" id="guest" class="peer appearance-none w-5 h-5 border-2 border-surface-300 rounded-full checked:border-brand transition-all" <%= oldInput.userType === 'guest' || !oldInput.userType ? 'checked' : '' %> />
                  <div class="absolute w-2.5 h-2.5 bg-brand rounded-full scale-0 peer-checked:scale-100 transition-transform"></div>
                </div>
                <span class="text-sm font-medium text-surface-600 group-hover:text-surface-900">Traveler / Guest</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <div class="relative w-5 h-5 flex items-center justify-center">
                  <input type="radio" name="userType" value="host" id="host" class="peer appearance-none w-5 h-5 border-2 border-surface-300 rounded-full checked:border-brand transition-all" <%= oldInput.userType === 'host' ? 'checked' : '' %>/>
                  <div class="absolute w-2.5 h-2.5 bg-brand rounded-full scale-0 peer-checked:scale-100 transition-transform"></div>
                </div>
                <span class="text-sm font-medium text-surface-600 group-hover:text-surface-900">Property Host</span>
              </label>
            </div>
          </div>

          <!-- Terms and conditions -->
          <div class="px-1">
            <label class="flex items-start gap-3 cursor-pointer group">
              <input type="checkbox" name="terms" id="terms" class="mt-1 appearance-none w-5 h-5 border-2 border-surface-300 rounded-md checked:bg-brand checked:border-brand transition-all cursor-pointer relative after:content-['✓'] after:absolute after:text-white after:left-1 after:top-[-2px] after:opacity-0 checked:after:opacity-100" required />
              <span class="text-sm text-surface-500 font-medium">I agree to the <a href="#" class="text-brand font-bold hover:underline">Terms of Service</a> and <a href="#" class="text-brand font-bold hover:underline">Privacy Policy</a></span>
            </label>
          </div> 

          <div class="pt-4">
            <button type="submit" class="w-full btn-primary py-4 text-lg font-bold shadow-xl shadow-brand/20">
              Create Account
            </button>
          </div>
          
          <p class="text-center text-surface-500 font-medium pt-2">
            Already have an account? <a href="/login" class="text-brand font-bold hover:underline">Log in here</a>
          </p>
        </form>
      </div>
    </main>

    <style>
      @keyframes fade-in {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-in { animation: fade-in 0.5s ease-out forwards; }
    </style>
  </body>
</html>
