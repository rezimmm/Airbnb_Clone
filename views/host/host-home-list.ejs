<%- include('../partials/head') %>
  </head>
  <body class="bg-surface-50 min-h-screen flex flex-col">
    <%- include('../partials/nav') %>
    
    <main class="container mx-auto px-4 py-12 flex-1 animate-fade-in">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10">
        <div>
          <h1 class="text-3xl font-bold text-surface-900">Your Hosting Dashboard</h1>
          <p class="text-surface-500 font-medium">Manage your properties and bookings</p>
        </div>
        <a href="/host/add-home" class="btn-primary flex items-center gap-2 self-start md:self-auto">
          <i class="fa-solid fa-plus text-sm"></i>
          <span>Add New Property</span>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-10">
        <% registeredHomes.forEach(home => { %>
          <div class="group bg-white rounded-3xl overflow-hidden border border-surface-100 shadow-sm hover:shadow-premium transition-all duration-300">
            <!-- Image -->
            <div class="relative aspect-[4/3] overflow-hidden">
              <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-full object-cover transition duration-500 group-hover:scale-110">
              <div class="absolute top-3 left-3 bg-brand text-white text-[10px] font-bold uppercase py-1 px-2 rounded-md shadow-lg">
                Active Listing
              </div>
            </div>

            <!-- Details -->
            <div class="p-5">
              <div class="flex justify-between items-start mb-2">
                <h3 class="font-bold text-surface-900 truncate pr-2"><%= home.houseName %></h3>
                <div class="flex items-center gap-1">
                  <i class="fa-solid fa-star text-[10px] text-surface-900"></i>
                  <span class="text-sm font-semibold text-surface-600"><%= home.rating %></span>
                </div>
              </div>
              
              <p class="text-surface-400 text-sm font-medium mb-4 flex items-center gap-1">
                <i class="fa-solid fa-location-dot text-xs"></i>
                <%= home.location %>
              </p>

              <div class="flex items-center justify-between pt-4 border-t border-surface-50">
                <div class="flex flex-col">
                  <span class="text-xs font-bold text-surface-400 uppercase">Per Night</span>
                  <span class="font-bold text-surface-900">Rs<%= home.price %></span>
                </div>
                
                <div class="flex gap-2">
                  <a href="/host/edit-home/<%=home._id%>?editing=true" class="w-10 h-10 rounded-xl bg-surface-50 text-surface-600 flex items-center justify-center hover:bg-brand hover:text-white transition-all shadow-sm">
                    <i class="fa-solid fa-pen-to-square text-sm"></i>
                  </a>
                  <form action="/host/delete-home/<%= home._id %>" method="POST" onsubmit="return confirm('Release this listing from AuraStay?')">
                    <button type="submit" class="w-10 h-10 rounded-xl bg-surface-50 text-red-500 flex items-center justify-center hover:bg-red-500 hover:text-white transition-all shadow-sm">
                      <i class="fa-solid fa-trash-can text-sm"></i>
                    </button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <% if (registeredHomes.length === 0) { %>
        <div class="flex flex-col items-center justify-center py-20 text-center bg-white rounded-3xl border border-dashed border-surface-200">
          <div class="w-16 h-16 bg-surface-50 rounded-full flex items-center justify-center mb-4">
            <i class="fa-solid fa-house-chimney-medical text-2xl text-surface-200"></i>
          </div>
          <h2 class="text-xl font-semibold text-surface-900">No properties listed yet</h2>
          <p class="text-surface-400 mt-2 max-w-xs">Start your hosting journey by adding your first property to AuraStay.</p>
          <a href="/host/add-home" class="btn-primary mt-6">Create Your First Listing</a>
        </div>
      <% } %>
    </main>

    <style>
      @keyframes fade-in {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-in { animation: fade-in 0.6s ease-out forwards; }
    </style>
  </body>
</html>
