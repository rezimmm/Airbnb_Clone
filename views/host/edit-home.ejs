<%- include('../partials/head') %>
  </head>
  <body class="bg-surface-50 min-h-screen flex flex-col">
    <%- include('../partials/nav') %>
    
    <main class="flex-1 flex items-center justify-center p-4 py-20 animate-fade-in">
      <div class="w-full max-w-2xl bg-white rounded-3xl shadow-premium border border-surface-100 p-8 md:p-12">
        <div class="text-center mb-10">
          <h1 class="text-3xl font-bold text-surface-900 mb-2"><%= editing ? "Edit" : "Register"%> Your Home</h1>
          <p class="text-surface-400 font-medium">Configure your property details for travelers</p>
        </div>

        <form action="/host/<%= editing ? "edit-home" : "add-home"%>" method="POST" enctype="multipart/form-data" class="space-y-6">
          <input type="hidden" name="id" value="<%= editing ? home._id : ''%>" />
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-surface-500 mb-2 ml-1">House Name</label>
              <input
                type="text"
                name="houseName"
                value="<%= editing ? home.houseName : ''%>"
                placeholder="Ex: Sunset Villa"
                class="input-premium"
                required/>
            </div>
            
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-surface-500 mb-2 ml-1">Price Per Night (Rs)</label>
              <input
                type="number"
                name="price"
                value="<%= editing ? home.price : ''%>"
                placeholder="Ex: 5500"
                class="input-premium"
                required/>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-surface-500 mb-2 ml-1">Location</label>
              <input
                type="text"
                name="location"
                value="<%= editing ? home.location : ''%>"
                placeholder="Ex: Mumbai, India"
                class="input-premium"
                required/>
            </div>
            
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-surface-500 mb-2 ml-1">Initial Rating</label>
              <input
                type="number"
                step="0.1"
                min="0"
                max="5"
                name="rating"
                value="<%= editing ? home.rating : ''%>"
                placeholder="Ex: 4.8"
                class="input-premium"
                required/>
            </div>
          </div>

          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-surface-500 mb-2 ml-1">Property Photo</label>
            <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-surface-200 border-dashed rounded-2xl hover:border-brand transition-colors cursor-pointer relative bg-surface-50">
              <div class="space-y-1 text-center">
                <i class="fa-solid fa-cloud-arrow-up text-3xl text-surface-300"></i>
                <div class="flex text-sm text-surface-600">
                  <label for="photo-upload" class="relative cursor-pointer font-semibold text-brand hover:text-brand-dark">
                    <span>Upload a file</span>
                    <input id="photo-upload" name="photo" type="file" class="sr-only" accept="image/jpg, image/jpeg, image/png" <%= editing ? "" : "required" %>>
                  </label>
                  <p class="pl-1">or drag and drop</p>
                </div>
                <p class="text-xs text-surface-400">PNG, JPG up to 10MB</p>
              </div>
            </div>
            <% if (editing && home.photo) { %>
              <p class="text-xs text-surface-400 mt-2">Current photo: <span class="font-mono text-[10px]"><%= home.photo.substring(home.photo.lastIndexOf('/') + 1) %></span></p>
            <% } %>
          </div>

          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-surface-500 mb-2 ml-1">Description</label>
            <textarea
              name="description"
              rows="4"
              placeholder="Tell guests what makes your place unique..."
              class="input-premium py-4"
              required><%= editing ? home.description : ''%></textarea>
          </div>

          <div class="pt-4 flex gap-4">
            <a href="/host/host-home-list" class="flex-1 btn-outline text-center py-4">Cancel</a>
            <button type="submit" class="flex-[2] btn-primary py-4 text-lg font-bold shadow-xl shadow-brand/20">
              <%= editing ? "Update Listing" : "Create Listing"%>
            </button>
          </div>
        </form>
      </div>
    </main>

    <style>
      @keyframes fade-in {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-in { animation: fade-in 0.6s ease-out forwards; }
    </style>
  </body>
</html>
